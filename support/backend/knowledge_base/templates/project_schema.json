{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ideaforge.ai/schemas/archived-project.schema.json",
  "title": "IdeaForge AI Archived Academic Project",
  "description": "Rich metadata schema for archived university projects used by the IdeaForge AI knowledge base ingestion pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_id",
    "basic_information",
    "academic_information",
    "abstract",
    "problem_statement",
    "objectives",
    "scope",
    "features",
    "modules",
    "technologies",
    "ai_usage",
    "algorithms",
    "difficulty",
    "estimated_duration",
    "team_size",
    "keywords",
    "research_area",
    "supervisor_specialization",
    "expected_outcomes",
    "limitations",
    "future_scope"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Stable archive identifier used across PostgreSQL and vector storage.",
      "pattern": "^project_[0-9]{4,}$",
      "examples": ["project_0001"]
    },
    "basic_information": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "short_title", "project_type", "status"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 8,
          "maxLength": 255
        },
        "short_title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "project_type": {
          "type": "string",
          "enum": ["capstone", "thesis", "research", "course_project", "prototype", "industry_project"]
        },
        "status": {
          "type": "string",
          "enum": ["archived", "published", "completed", "approved"]
        },
        "summary": {
          "type": "string",
          "minLength": 40
        },
        "repository_url": {
          "type": ["string", "null"],
          "format": "uri"
        },
        "demo_url": {
          "type": ["string", "null"],
          "format": "uri"
        }
      }
    },
    "academic_information": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "institution",
        "department",
        "program",
        "course_code",
        "academic_level",
        "academic_year",
        "semester",
        "authors",
        "supervisor"
      ],
      "properties": {
        "institution": {
          "type": "string",
          "minLength": 3
        },
        "faculty": {
          "type": "string"
        },
        "department": {
          "type": "string",
          "minLength": 2
        },
        "program": {
          "type": "string",
          "minLength": 2
        },
        "course_code": {
          "type": "string"
        },
        "course_title": {
          "type": "string"
        },
        "academic_level": {
          "type": "string",
          "enum": ["undergraduate", "graduate", "postgraduate"]
        },
        "academic_year": {
          "type": "string",
          "pattern": "^[0-9]{4}(-[0-9]{4})?$"
        },
        "semester": {
          "type": "string",
          "enum": ["spring", "summer", "fall", "winter", "year_long"]
        },
        "submission_date": {
          "type": "string",
          "format": "date"
        },
        "authors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/person"
          }
        },
        "supervisor": {
          "$ref": "#/$defs/person"
        },
        "co_supervisor": {
          "anyOf": [
            { "$ref": "#/$defs/person" },
            { "type": "null" }
          ]
        },
        "evaluation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "grade": { "type": "string" },
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "award_or_recognition": { "type": ["string", "null"] }
          }
        }
      }
    },
    "abstract": {
      "type": "string",
      "minLength": 100
    },
    "problem_statement": {
      "type": "string",
      "minLength": 80
    },
    "objectives": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary"],
      "properties": {
        "primary": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 10 }
        },
        "secondary": {
          "type": "array",
          "items": { "type": "string", "minLength": 10 }
        }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded", "target_users"],
      "properties": {
        "included": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" }
        },
        "target_users": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "deployment_context": {
          "type": "string"
        }
      }
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "priority"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string", "minLength": 15 },
          "priority": {
            "type": "string",
            "enum": ["core", "important", "optional"]
          },
          "user_roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose", "responsibilities"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string", "minLength": 15 },
          "responsibilities": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "technologies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["programming_languages", "frameworks", "database", "apis", "tools", "platforms"],
      "properties": {
        "programming_languages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/technology_item" }
        },
        "frameworks": {
          "type": "array",
          "items": { "$ref": "#/$defs/technology_item" }
        },
        "libraries": {
          "type": "array",
          "items": { "$ref": "#/$defs/technology_item" }
        },
        "database": {
          "type": "array",
          "items": { "$ref": "#/$defs/technology_item" }
        },
        "apis": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "purpose"],
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" },
              "provider": { "type": "string" },
              "integration_type": {
                "type": "string",
                "enum": ["internal", "external", "third_party", "mock"]
              }
            }
          }
        },
        "tools": {
          "type": "array",
          "items": { "$ref": "#/$defs/technology_item" }
        },
        "platforms": {
          "type": "array",
          "items": { "$ref": "#/$defs/technology_item" }
        }
      }
    },
    "ai_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uses_ai", "description", "techniques"],
      "properties": {
        "uses_ai": { "type": "boolean" },
        "description": { "type": "string" },
        "techniques": {
          "type": "array",
          "items": { "type": "string" }
        },
        "models": {
          "type": "array",
          "items": { "type": "string" }
        },
        "training_data": {
          "type": "string"
        },
        "evaluation_metrics": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "algorithms": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["search", "ranking", "classification", "prediction", "optimization", "security", "data_processing", "recommendation", "other"]
          },
          "complexity": { "type": "string" }
        }
      }
    },
    "difficulty": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "score", "reasons"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["beginner", "intermediate", "advanced", "research_intensive"]
        },
        "score": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "prerequisites": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "estimated_duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "unit"],
      "properties": {
        "value": {
          "type": "integer",
          "minimum": 1
        },
        "unit": {
          "type": "string",
          "enum": ["weeks", "months", "semesters"]
        },
        "phase_breakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "duration"],
            "properties": {
              "phase": { "type": "string" },
              "duration": { "type": "string" }
            }
          }
        }
      }
    },
    "team_size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minimum", "recommended", "maximum"],
      "properties": {
        "minimum": {
          "type": "integer",
          "minimum": 1
        },
        "recommended": {
          "type": "integer",
          "minimum": 1
        },
        "maximum": {
          "type": "integer",
          "minimum": 1
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "keywords": {
      "type": "array",
      "minItems": 3,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "research_area": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary", "secondary"],
      "properties": {
        "primary": { "type": "string" },
        "secondary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "application_domain": { "type": "string" }
      }
    },
    "supervisor_specialization": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "expected_outcomes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 10 }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 }
    },
    "future_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 10 }
    },
    "search_metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "search_boost_terms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_project_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "suitable_for_students_with": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2
        },
        "student_id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "department": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    },
    "technology_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "purpose"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "purpose": { "type": "string" },
        "category": { "type": "string" }
      }
    }
  }
}
